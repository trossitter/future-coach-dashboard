# Anthropic Haiku is the default LLM path and keeps prompt caching enabled.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# Optional OpenAI-compatible fallback through Venice / Qwen.
VENICE_API_KEY=
LLM_BASE_URL=https://api.venice.ai/api/v1
MODEL_INTENT=qwen3-next-80b
MODEL_NARRATE=qwen3-next-80b
MODEL_COPILOT=qwen3-next-80b

# Local / bring-your-own-model path — any OpenAI-compatible server (Ollama,
# LM Studio, llama.cpp, vLLM). No hosted key, no per-token cost. The base URL
# targets the host's server as seen from inside Docker. LOCAL_API_KEY stays
# empty for keyless local servers; set it only for a hosted endpoint.
#   LLM_PROVIDER=local
LOCAL_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_MODEL=llama3.1
LOCAL_API_KEY=
